# .env.exemplo — modelo do ~/.hermes/.env (SEGREDOS) para o Tutor LDC
# ===========================================================================
# COPIE para ~/.hermes/.env e preencha. NUNCA versione o .env real
# (já ignorado pelo .gitignore: .env e .env.*). Cada valor abaixo é PLACEHOLDER.
# Quem gera cada um: ver PROGRESS.md > PRECISO DE VOCÊ e os runbooks citados.
# ===========================================================================

# --- Provedor de modelo (escolha UM; ver SETUP-HERMES.md §2) ---------------
# Use a env do provedor que você configurou em `hermes model`.
OPENROUTER_API_KEY=<<<PREENCHER: chave do provedor de modelo (ou ANTHROPIC_API_KEY etc.)>>>

# --- Telegram (ver SETUP-HERMES.md §4) -------------------------------------
TELEGRAM_BOT_TOKEN=<<<PREENCHER: token do BotFather, formato 123456789:ABC...>>>
# Trava o bot só para você. Seu user ID numérico (via @userinfobot). Vírgula p/ múltiplos.
TELEGRAM_ALLOWED_USERS=<<<PREENCHER: seu user ID numérico do Telegram>>>

# --- Notion MCP (a MESMA integração do CRM; ver crm-notion/SETUP-NOTION.md §1) ---
NOTION_TOKEN=<<<PREENCHER: Internal Integration Secret do Notion (ntn_... ou secret_...)>>>
# Opcional, usado pelo script de setup das bases (não pelo MCP):
NOTION_PARENT_PAGE_ID=<<<PREENCHER: ID da página-pai compartilhada com a integração>>>
